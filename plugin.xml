<?xml version="1.0" encoding="UTF-8"?>
<plugin id="cordova-plugin-faceki-blaze"
        version="1.0.0"
        xmlns="http://apache.org/cordova/ns/plugins/1.0"
        xmlns:android="http://schemas.android.com/apk/res/android">

    <name>FacekiBlaze</name>
    <description>Faceki Blaze Cordova Plugin (iOS + Android)</description>
    <license>MIT</license>

    <!-- ================= JS ================= -->
    <js-module src="www/FacekiBlaze.js" name="FacekiBlaze">
        <clobbers target="cordova.plugins.FacekiBlaze" />
    </js-module>

    <!-- ================= iOS ================= -->

<platform name="ios">

        <!-- ✅ Register plugin -->
        <config-file target="config.xml" parent="/*">
            <feature name="FacekiBlaze">
                <param name="ios-package" value="FacekiBlaze" />
            </feature>
        </config-file>

      

        <!-- ✅ Swift file ONLY -->
        <source-file src="src/ios/FacekiBlaze.swift" />

        <!-- ✅ CocoaPods SDK -->
        <podspec>
            <config>
                <source url="https://cdn.cocoapods.org/" />
            </config>
            <pods>
                <pod name="FACEKI-BLAZE-IOS" spec="~> 3.2.0" />
            </pods>
        </podspec>

        <!-- ✅ Permissions -->
        <edit-config file="*-Info.plist"
                     target="NSCameraUsageDescription"
                     mode="merge">
            <string>Camera is required for identity verification</string>
        </edit-config>

    </platform>


    <!-- ================= ANDROID ================= -->
 <!-- ✅ Android Platform -->
    <platform name="android">

        <!-- ✅ Java class -->
        <source-file src="src/android/FacekiBlaze.java"
                     target-dir="app/src/main/java/com/yourplugin" />

        <!-- ✅ Register plugin -->
        <config-file target="config.xml" parent="/*">
            <feature name="FacekiBlaze">
                <param name="android-package" value="com.yourplugin.FacekiBlaze"/>
            </feature>
        </config-file>

        <!-- ✅ Add permissions -->
        <config-file target="AndroidManifest.xml" parent="/manifest">
            <uses-permission android:name="android.permission.CAMERA" />
            <uses-permission android:name="android.permission.INTERNET" />
        </config-file>

        <!-- ✅ Add Maven repository (jitpack required for Faceki SDK) -->
        <config-file target="app/build.gradle" parent="allprojects/repositories">
            <repository>
                <url>https://jitpack.io</url>
            </repository>
        </config-file>

        <!-- ✅ Add dependency -->
        <framework src="com.github.faceki:blaze-android-sdk:2.1" />

    </platform>

</plugin>
